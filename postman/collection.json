{
  "info": {
    "name": "TKD Tournament API",
    "description": "Postman collection for the Taekwondo Match Management System\n\nBase URL: {{base_url}}\nAuth: Bearer token via {{auth_token}}\n\nEndpoints:\n- Health: GET /api/healthz\n- Auth: POST /api/auth/tkd/login, POST /api/auth/signup, POST /api/auth/login, GET /api/auth/me, PATCH /api/auth/me\n- Clubs: GET/POST /api/clubs\n- Tournaments: GET/POST /api/tournaments, GET /api/tournaments/:id, PUT /api/tournaments/:id/settings, GET /api/tournaments/:id/excluded-players\n- Players: GET/POST /api/players, POST /api/players/bulk\n- Matches: POST /api/matches/generate, GET /api/matches/:id\n- Match State: POST /api/matches/:id/start|pause|resume|end|cancel\n- HTTP Fallback Scoring: POST /api/matches/:id/points, POST /api/matches/:id/remove-points, POST /api/matches/:id/end-round\n---\nAdded by Bracket Progression Flow:\n- GET /api/tournaments/:id/bracket\n- POST /api/tournaments/:id/bracket/override\n- endReason added to End Match payload\n- WebSocket Events folder (documentation)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "auth_token",
      "value": ""
    },
    {
      "key": "tournament_id",
      "value": ""
    },
    {
      "key": "player_id",
      "value": ""
    },
    {
      "key": "club_id",
      "value": ""
    },
    {
      "key": "match_id",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
